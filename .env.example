# Database
DATABASE_URL=postgresql://watchscraper:watchscraper@localhost:5433/watchscraper

# eBay (optional — HTML scraping works without keys)
EBAY_APP_ID=
EBAY_CERT_ID=

# WatchCharts API ($30/mo subscription)
WATCHCHARTS_API_KEY=

# Scraper settings
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=5.0
LOG_LEVEL=INFO
